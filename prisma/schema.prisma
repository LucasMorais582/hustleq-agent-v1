generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  conversations   Conversation[]
  businessContext BusinessContext?
  integrations    Integration[]
}

model Conversation {
  id        String   @id @default(uuid())
  title     String?
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  messages Message[]
}

model Message {
  id        String   @id @default(uuid())
  role      String
  content   String
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model BusinessContext {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  // 🧠 BUSINESS
  businessName    String?
  description     String?
  niche           String?
  location        String?
  experienceLevel String?
  type            String? // services, products, both

  // 🧠 OFFERINGS
  offerings       String[] // simples e suficiente

  // 🧠 AUDIENCE
  idealCustomer   String?
  mainProblem     String?
  customerMindset String?
  acquisitionChannels String[]

  // 🧠 GOALS
  primaryGoals    String[] // ENGAGEMENT, CONVERSION, etc
  successDefinition String?
  shortTermStrategy String?

  // 🧠 BRAND VOICE
  tone            String[]
  desiredFeeling  String?
  avoidTopics     String[]

  // 🧠 CONTENT STRATEGY
  contentFocus    String[]
  currentIssues   String[]
  desiredShift    String?

  // 🧠 REFERENCES
  inspirations    String[]
  competitors     String[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContentStrategy {
  id          String   @id @default(uuid())
  userId      String

  name        String
  description String?

  pillars     Json     //aqui vai o resultado do prompt

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model ContentPlan {
  id        String   @id @default(uuid())
  userId    String
  name      String?
  strategyId String?
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integration {
  id           String   @id @default(uuid())
  provider     String
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}